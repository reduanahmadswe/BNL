{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Banglish BNL",
  "scopeName": "source.bnl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.bnl",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.bnl",
          "match": "\\b(dorlam|dekhao|guraw|shesh)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.word.bnl",
          "match": "\\b(jog|biyog|gun|vag)\\b"
        },
        {
          "name": "keyword.operator.symbol.bnl",
          "match": "==|!=|<=|>=|<|>"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.bnl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.bnl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.bnl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.bnl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.bnl",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.bnl",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
